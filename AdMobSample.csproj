<Project Sdk="Godot.NET.Sdk/4.5.0">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
  </PropertyGroup>
  <ItemGroup>
    <!-- Addon source is compiled by its own project; exclude it here -->
    <Compile Remove="addons\admob\src\**\*.cs" />
    <!-- Android export copies files into android/build; exclude to avoid duplicate type conflicts with AdMobAddon reference -->
    <Compile Remove="android\**\*.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="addons\admob\AdMobAddon.csproj" />
  </ItemGroup>
</Project>
